# Leave these unset to use same-origin defaults (works with Vite dev-server proxy + ngrok).
# If your backend is hosted elsewhere, set VITE_API_BASE_URL and (optionally) VITE_WS_BASE_URL.
# VITE_API_BASE_URL=
# VITE_WS_BASE_URL=
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
